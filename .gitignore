# Ignore Python Virtual Environments
.venv/
venv/
env/
ENV/

# Ignore Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Ignore Environment Variables (API Keys!)
.env

# Ignore large executables & tools
ffmpeg.exe
test_tts.wav
temp.wav

# Ignore Temporary Upload Audio Folders
temp/

# Ignore Downloaded Model files (Heavy files > 100MB)
app/whisper.cpp/models/ggml-*.bin
# Abaikan folder build di whisper supaya tidak menuhin repo
app/whisper.cpp/build/

# Ignore Dataset Audio File (Menghindari limitasi ukuran Github repo)
data/corpus/audio/*.wav
data/corpus/audio/*.mp3
data/corpus/audio/*.m4a

# Ignore log
log/hasil_evaluasi.csv